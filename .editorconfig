root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{tex,md,yml,yaml,json,sh}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf

[*.ps1]
end_of_line = crlf
indent_style = space
indent_size = 2

[*.pdf]
insert_final_newline = false
trim_trailing_whitespace = false